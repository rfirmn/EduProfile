# App
PORT=3000
NODE_ENV=development
API_PREFIX=v1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/eduprofile?schema=public"

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

# ML Model API
ML_API_URL=http://localhost:8000/predict

# Learning Pace Thresholds
PACE_FAST_THRESHOLD_MS=40000
PACE_SLOW_THRESHOLD_MS=70000
PACE_ACCURACY_THRESHOLD_PCT=70

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=password
